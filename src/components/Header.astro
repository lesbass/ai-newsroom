---
const currentPath = Astro.url.pathname;
function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---
<header>
  <div class="container">
    <a href="/" class="site-logo">AI Newsroom</a>
    <nav class="nav-links">
      <a href="/" class={isCurrent('/') && !isCurrent('/articles') && !isCurrent('/tags') && !isCurrent('/corrections') ? 'current' : ''}>Home</a>
      <a href="/articles/" class={isCurrent('/articles') ? 'current' : ''}>Articles</a>
      <a href="/tags/" class={isCurrent('/tags') ? 'current' : ''}>Topics</a>
      <a href="/corrections/" class={isCurrent('/corrections') ? 'current' : ''}>Corrections</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>
</header>
