---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { slugifyTag } from '../../lib/slugify';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const tagSet = new Set<string>();

  for (const article of articles) {
    for (const tag of article.data.tags) {
      const slug = slugifyTag(tag);
      if (slug) tagSet.add(slug);
    }
  }

  return [...tagSet].map(tag => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const allArticles = await getCollection('articles');

const matchingArticles = allArticles
  .filter(article =>
    article.data.tags.some(t => slugifyTag(t) === tag)
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const displayTag = tag.replace(/-/g, ' ');
---

<BaseLayout
  title={`${displayTag} articles`}
  description={`Evidence-based AI news articles tagged with "${displayTag}". ${matchingArticles.length} article${matchingArticles.length !== 1 ? 's' : ''}.`}
>
  <Header />
  <main class="container" id="main-content">
    <div class="tag-page-header">
      <h1>{displayTag}</h1>
      <p class="tag-page-count">{matchingArticles.length} article{matchingArticles.length !== 1 ? 's' : ''}</p>
      <p style="margin-top: 0.75rem;"><a href="/tags/">&larr; All topics</a></p>
    </div>
    {matchingArticles.length > 0 ? (
      <div>
        {matchingArticles.map(article => (
          <ArticleCard article={article} />
        ))}
      </div>
    ) : (
      <p style="text-align: center; color: var(--color-muted);">No articles found for this topic.</p>
    )}
  </main>
  <Footer />
</BaseLayout>
