---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { slugifyTag } from '../../lib/slugify';

export async function getStaticPaths() {
  const posts = await getCollection('articles');
  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'articles'>;

const post = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, author, tags, sources, highRiskClaims, canonicalURL, image, imageAlt, imageCredit } = post.data;
const date = new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updated = updatedDate ? new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : null;

const body = post.body || '';
const wordCount = body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 238));
const displayTags = tags.slice(0, 6);
const extraTagCount = Math.max(0, tags.length - 6);
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  pubDate={pubDate}
  updatedDate={updatedDate || pubDate}
  author={author}
  article={true}
  canonicalURL={canonicalURL}
  tags={tags}
>
  <Header />
  <main id="main-content">
  <article class="container article-body">
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Articles', href: '/articles/' },
        { label: title },
      ]}
    />
    <div class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <span>{date}</span>
        {updated && <span> (updated {updated})</span>}
        <span class="sep-dot">&middot;</span>
        <span>{author}</span>
        <span class="sep-dot">&middot;</span>
        <span class="reading-time">{readingTime} min read</span>
        {sources.length > 0 && (
          <>
            <span class="sep-dot">&middot;</span>
            <span>{sources.length} source{sources.length !== 1 ? 's' : ''}</span>
          </>
        )}
      </div>
      <div style="margin-top: 0.5rem;">
        {displayTags.map(t => <a href={`/tags/${slugifyTag(t)}/`} class="tag">{t}</a>)}
        {extraTagCount > 0 && <span class="tag">+{extraTagCount}</span>}
        {highRiskClaims && <span class="tag tag-highlight">high-risk claims</span>}
      </div>
    </div>
    {image && (
      <figure class="article-hero">
        <img src={image} alt={imageAlt || title} loading="eager" />
        {imageCredit && <figcaption class="article-hero-credit">{imageCredit}</figcaption>}
      </figure>
    )}
    <Content />
    {sources.length > 0 && (
      <aside style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border);">
        <h2 style="font-size: 1.125rem; margin-bottom: 0.75rem;">Sources</h2>
        <ul class="sources-list">
          {sources.map(source => (
            <li>
              <a href={source.url} target="_blank" rel="noopener noreferrer">{source.title}</a>
              {source.date && <span style="color: var(--color-muted);"> ({new Date(source.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })})</span>}
              {source.type === 'secondary' && <span class="source-type"> [secondary]</span>}
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>
  </main>
  <Footer />
</BaseLayout>
