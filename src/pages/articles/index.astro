---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Articles"
  description="Evidence-based AI news articles with dated sources and strict editorial quality gates."
>
  <Header />
  <main class="container" id="main-content">
    <h1 style="margin: 2rem 0 1rem;">Articles</h1>
    <ul class="article-list">
      {sorted.map(article => <ArticleCard article={article} />)}
    </ul>
  </main>
  <Footer />
</BaseLayout>
