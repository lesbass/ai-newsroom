---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you requested could not be found."
>
  <Header />
  <main class="container" style="margin: 4rem 0; text-align: center;" id="main-content">
    <h1 style="font-size: 3rem; margin-bottom: 0.5rem;">404</h1>
    <p style="font-size: 1.125rem; color: var(--color-muted);">The page you requested could not be found.</p>
    <p><a href="/">Return home</a> or <a href="/articles/">browse articles</a>.</p>
  </main>
  <Footer />
</BaseLayout>
