---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  article?: boolean;
}

const { title, description, image, canonicalURL, pubDate, updatedDate, author = 'AI Newsroom', article = false } = Astro.props;
const site = 'https://ai-newsroom.pages.dev';
const fullTitle = title === 'AI Newsroom' ? title : `${title} — AI Newsroom`;
const pageURL = canonicalURL || new URL(Astro.url.pathname, site).toString();

const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'NewsArticle',
      headline: title,
      description: description,
      url: pageURL,
      ...(image && { image: new URL(image, site).toString() }),
      datePublished: pubDate ? pubDate.toISOString() : undefined,
      dateModified: updatedDate ? updatedDate.toISOString() : pubDate ? pubDate.toISOString() : undefined,
      author: {
        '@type': 'Organization',
        name: author,
        url: site,
      },
      publisher: {
        '@type': 'Organization',
        name: 'AI Newsroom',
        logo: {
          '@type': 'ImageObject',
          url: new URL('/favicon.svg', site).toString(),
        },
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'AI Newsroom',
      url: site,
      description: description,
    };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0b0b0b" media="(prefers-color-scheme: dark)" />
  <link rel="canonical" href={pageURL} />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="alternate" type="application/rss+xml" title="AI Newsroom" href="/rss.xml" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={pageURL} />
  <meta property="og:type" content={article ? 'article' : 'website'} />
  {image && <meta property="og:image" content={new URL(image, site).toString()} />}
  <meta property="og:site_name" content="AI Newsroom" />

  <!-- Twitter -->
  <meta name="twitter:card" content={article && image ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {image && <meta name="twitter:image" content={new URL(image, site).toString()} />}

  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {article && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

  <!-- JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <style is:global>
    :root {
      --color-bg: #ffffff;
      --color-text: #111111;
      --color-muted: #555555;
      --color-border: #e5e5e5;
      --color-accent: #2563eb;
      --font-body: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      --max-width: 720px;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --color-bg: #0b0b0b;
        --color-text: #eeeeee;
        --color-muted: #aaaaaa;
        --color-border: #333333;
        --color-accent: #60a5fa;
      }
    }
    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      margin: 0;
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.6;
      overflow-wrap: break-word;
    }
    a { color: var(--color-accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    table {
      display: block;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border-collapse: collapse;
    }
    th, td {
      border: 1px solid var(--color-border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }
    th { background: var(--color-border); font-weight: 600; }
    pre, code { font-family: var(--font-mono); font-size: 0.95em; }
    pre {
      background: var(--color-border);
      padding: 1rem;
      border-radius: 0.5rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    blockquote {
      border-left: 4px solid var(--color-accent);
      margin: 1rem 0;
      padding-left: 1rem;
      color: var(--color-muted);
    }
    h1, h2, h3, h4 { line-height: 1.2; margin: 1.5rem 0 0.75rem; }
    p { margin: 0.75rem 0; }
    ul, ol { margin: 0.75rem 0; padding-left: 1.25rem; }
    .container {
      width: 100%;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1rem;
    }
    header, footer {
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 0;
    }
    footer {
      border-bottom: none;
      border-top: 1px solid var(--color-border);
      margin-top: 2rem;
      color: var(--color-muted);
      font-size: 0.9rem;
    }
    .nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .nav a { font-weight: 600; }
    .nav-links { display: flex; gap: 1rem; flex-wrap: wrap; }
    .nav-links a { min-height: 44px; display: inline-flex; align-items: center; }
    .article-list { list-style: none; padding: 0; }
    .article-list li { border-bottom: 1px solid var(--color-border); padding: 1rem 0; }
    .article-list a { font-size: 1.125rem; font-weight: 600; }
    .article-meta { color: var(--color-muted); font-size: 0.875rem; }
    .article-header { margin: 2rem 0 1rem; }
    .article-header h1 { margin: 0; font-size: 1.75rem; }
    .article-body { font-size: 1.0625rem; }
    .tag { display: inline-block; background: var(--color-border); color: var(--color-muted); padding: 0.125rem 0.5rem; border-radius: 999px; font-size: 0.75rem; margin-right: 0.25rem; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
