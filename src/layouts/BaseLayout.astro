---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  article?: boolean;
  tags?: string[];
}

const { title, description, image, canonicalURL, pubDate, updatedDate, author = 'AI Newsroom', article = false, tags = [] } = Astro.props;
const site = 'https://news.lesbass.com/';
const fullTitle = title === 'AI Newsroom' ? title : `${title} — AI Newsroom`;
const pageURL = canonicalURL || new URL(Astro.url.pathname, site).toString();

function truncateDescription(text: string, maxLen = 155): string {
  if (text.length <= maxLen) return text;
  const cut = text.slice(0, maxLen);
  const lastPeriod = cut.lastIndexOf('. ');
  const lastExcl = cut.lastIndexOf('! ');
  const lastQuest = cut.lastIndexOf('? ');
  const lastBreak = Math.max(lastPeriod, lastExcl, lastQuest);
  if (lastBreak > maxLen * 0.6) return text.slice(0, lastBreak + 1);
  return cut.slice(0, cut.lastIndexOf(' ')) + '…';
}

const seoDescription = truncateDescription(description);

const jsonLdImage = new URL(image || '/og-image.svg', site).toString();
const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'NewsArticle',
      '@id': `${pageURL}#article`,
      headline: title,
      description: description,
      url: pageURL,
      image: jsonLdImage,
      datePublished: pubDate ? pubDate.toISOString() : undefined,
      dateModified: updatedDate ? updatedDate.toISOString() : pubDate ? pubDate.toISOString() : undefined,
      author: {
        '@type': 'Organization',
        name: author,
        url: site,
      },
      publisher: {
        '@type': 'Organization',
        '@id': `${site}#organization`,
        name: 'AI Newsroom',
        url: site,
        logo: {
          '@type': 'ImageObject',
          url: new URL('/favicon.svg', site).toString(),
        },
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': pageURL,
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${site}#website`,
      name: 'AI Newsroom',
      url: site,
      description: description,
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${site}search?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{fullTitle}</title>
  <meta name="description" content={seoDescription} />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0b0b0b" media="(prefers-color-scheme: dark)" />
  <link rel="canonical" href={pageURL} />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="alternate" type="application/rss+xml" title="AI Newsroom" href="/rss.xml" />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={seoDescription} />
  <meta property="og:url" content={pageURL} />
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={image ? new URL(image, site).toString() : new URL('/og-image.svg', site).toString()} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="AI Newsroom" />

  <!-- Twitter -->
  <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={seoDescription} />
  <meta name="twitter:image" content={image ? new URL(image, site).toString() : new URL('/og-image.svg', site).toString()} />
  <meta name="twitter:image:alt" content={title} />

  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {article && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {article && tags.map(tag => <meta property="article:tag" content={tag} />)}

  <!-- JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <style is:inline>
    :root {
      --color-bg: #faf9f7;
      --color-surface: #ffffff;
      --color-text: #1a1a1a;
      --color-muted: #6b6b6b;
      --color-faint: #949494;
      --color-border: #e6e4e0;
      --color-accent: #2563eb;
      --color-accent-hover: #1d4ed8;
      --color-accent-subtle: #eff6ff;
      --color-highlight: #d97706;
      --color-highlight-subtle: #fffbeb;
      --font-heading: Georgia, 'Times New Roman', serif;
      --font-body: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      --max-width: 720px;
      --radius-sm: 0.375rem;
      --radius-md: 0.5rem;
      --radius-lg: 0.75rem;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --color-bg: #0f172a;
        --color-surface: #1e293b;
        --color-text: #f1f5f9;
        --color-muted: #94a3b8;
        --color-faint: #64748b;
        --color-border: #334155;
        --color-accent: #60a5fa;
        --color-accent-hover: #93bbfd;
        --color-accent-subtle: #1e3a5f;
        --color-highlight: #fbbf24;
        --color-highlight-subtle: #422006;
      }
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.7;
      overflow-wrap: break-word;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    a { color: var(--color-accent); text-decoration: none; transition: color 0.15s ease; }
    a:hover { color: var(--color-accent-hover); text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    table {
      display: block;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border-collapse: collapse;
      font-size: 0.9375rem;
    }
    th, td {
      border: 1px solid var(--color-border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }
    th { background: var(--color-border); font-weight: 600; }
    pre, code { font-family: var(--font-mono); font-size: 0.9em; }
    pre {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      padding: 1rem 1.25rem;
      border-radius: var(--radius-md);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      line-height: 1.6;
    }
    code { font-size: 0.9em; }
    :not(pre) > code {
      background: var(--color-border);
      padding: 0.125rem 0.375rem;
      border-radius: var(--radius-sm);
      font-size: 0.875em;
    }
    blockquote {
      border-left: 3px solid var(--color-accent);
      margin: 1.25rem 0;
      padding: 0.5rem 0 0.5rem 1.25rem;
      color: var(--color-muted);
      font-style: italic;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      line-height: 1.3;
      margin: 2rem 0 0.75rem;
      font-weight: 700;
      color: var(--color-text);
    }
    h1 { font-size: 1.875rem; letter-spacing: -0.02em; }
    h2 { font-size: 1.5rem; letter-spacing: -0.01em; }
    h3 { font-size: 1.25rem; }
    h4 { font-size: 1.1rem; }
    p { margin: 0.75rem 0; }
    ul, ol { margin: 0.75rem 0; padding-left: 1.5rem; }
    li { margin: 0.25rem 0; }
    .container {
      width: 100%;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    .container-wide {
      width: 100%;
      max-width: 960px;
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    header {
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(8px);
    }
    header .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }
    footer {
      background: var(--color-surface);
      border-top: 1px solid var(--color-border);
      margin-top: 3rem;
      padding: 2rem 0;
      color: var(--color-muted);
      font-size: 0.875rem;
    }
    .nav-links { display: flex; gap: 0.25rem; flex-wrap: wrap; align-items: center; }
    .nav-links a {
      font-weight: 500;
      font-size: 0.9375rem;
      padding: 0.375rem 0.75rem;
      border-radius: var(--radius-sm);
      min-height: 40px;
      display: inline-flex;
      align-items: center;
      color: var(--color-muted);
      transition: background 0.15s ease, color 0.15s ease;
    }
    .nav-links a:hover { background: var(--color-accent-subtle); color: var(--color-accent); text-decoration: none; }
    .nav-links a.current { background: var(--color-accent-subtle); color: var(--color-accent); font-weight: 600; }
    .site-logo {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--color-text);
      min-height: 40px;
      display: inline-flex;
      align-items: center;
      letter-spacing: -0.01em;
      transition: color 0.15s ease;
    }
    .site-logo:hover { color: var(--color-accent); text-decoration: none; }
    .article-list { list-style: none; padding: 0; margin: 0; }
    .article-list > li { margin-bottom: 0; }
    .article-card {
      display: block;
      padding: 1.25rem 1rem;
      border-bottom: 1px solid var(--color-border);
      transition: background 0.15s ease;
    }
    .article-card:hover { background: var(--color-surface); }
    .article-card:first-child { border-top: 1px solid var(--color-border); }
    .article-card-title {
      font-family: var(--font-heading);
      font-size: 1.125rem;
      font-weight: 700;
      line-height: 1.35;
      display: block;
      margin-bottom: 0.25rem;
    }
    .article-meta {
      color: var(--color-muted);
      font-size: 0.8125rem;
      line-height: 1.6;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.25rem;
    }
    .article-desc {
      color: var(--color-muted);
      font-size: 0.9375rem;
      margin: 0.35rem 0 0;
      line-height: 1.55;
    }
    .article-header { margin: 1rem 0 2rem; }
    .article-header h1 {
      margin: 0 0 0.5rem;
      font-size: 2rem;
      line-height: 1.2;
    }
    .article-body {
      font-size: 1.0625rem;
      line-height: 1.75;
    }
    .article-body h2 { margin-top: 2.5rem; }
    .article-body h3 { margin-top: 2rem; }
    .tag {
      display: inline-block;
      background: var(--color-border);
      color: var(--color-muted);
      padding: 0.15rem 0.6rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 500;
      white-space: nowrap;
      transition: background 0.15s ease, color 0.15s ease;
      line-height: 1.4;
    }
    a.tag:hover {
      background: var(--color-accent-subtle);
      color: var(--color-accent);
      text-decoration: none;
    }
    .tag-highlight {
      background: var(--color-highlight-subtle);
      color: var(--color-highlight);
      font-weight: 600;
    }
    .home-hero {
      margin: 4rem auto 3rem;
      text-align: center;
      padding-top: 0;
      padding-bottom: 0;
    }
    .home-hero h1 { font-size: 2.5rem; line-height: 1.15; margin: 0 0 0.25rem; }
    .home-tagline {
      color: var(--color-muted);
      font-size: 1.125rem;
      margin: 0.25rem auto 0;
      line-height: 1.5;
      max-width: 480px;
    }
    .section-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-faint);
      margin: 2.5rem 0 0.75rem;
      font-family: var(--font-body);
      font-weight: 600;
    }
    .card-featured { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; margin-bottom: 1.5rem; }
    .card-featured .article-card-title { font-size: 1.375rem; }
    .card-featured .article-desc { font-size: 1rem; }
    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1rem 0;
    }
    .tag-cloud .tag {
      font-size: 0.8125rem;
      padding: 0.3rem 0.75rem;
    }
    .tag-page-header {
      margin: 2rem 0 1.5rem;
      text-align: center;
    }
    .tag-page-header h1 { font-size: 1.75rem; margin-bottom: 0.25rem; }
    .tag-page-header .tag-page-count { color: var(--color-muted); font-size: 0.9375rem; }
    .tags-index-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0.5rem;
      margin: 1.5rem 0;
    }
    .tag-index-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.6rem 0.875rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      font-size: 0.875rem;
      font-weight: 500;
      transition: background 0.15s ease, border-color 0.15s ease;
    }
    .tag-index-card:hover {
      background: var(--color-accent-subtle);
      border-color: var(--color-accent);
      text-decoration: none;
      color: var(--color-accent);
    }
    .tag-index-count {
      color: var(--color-faint);
      font-size: 0.75rem;
      font-weight: 600;
    }
    .skip-link {
      position: absolute;
      top: -100%;
      left: 0;
      background: var(--color-accent);
      color: #fff;
      padding: 0.5rem 1rem;
      z-index: 100;
      font-weight: 600;
      text-decoration: none;
      border-radius: 0 0 var(--radius-sm) 0;
    }
    .skip-link:focus { top: 0; }
    .breadcrumb { font-size: 0.8125rem; color: var(--color-muted); margin: 0.25rem 0 0.75rem; }
    .breadcrumb ol { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.25rem; align-items: center; }
    .breadcrumb li { display: flex; align-items: center; gap: 0.25rem; }
    .breadcrumb a { color: var(--color-muted); }
    .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
    .breadcrumb-sep { color: var(--color-border); user-select: none; }
    .reading-time { font-size: 0.8125rem; color: var(--color-muted); }
    .sep-dot { color: var(--color-border); user-select: none; margin: 0 0.125rem; }
    .sources-list { list-style: none; padding: 0; font-size: 0.875rem; }
    .sources-list li { margin-bottom: 0.5rem; }
    .source-type { color: var(--color-faint); font-size: 0.75rem; }
    .article-hero { margin: 0 0 1.5rem; }
    .article-hero img {
      width: 100%;
      height: auto;
      border-radius: 0.5rem;
      border: 1px solid var(--color-border);
    }
    .article-hero-credit {
      margin: 0.375rem 0 0;
      font-size: 0.75rem;
      color: var(--color-muted);
      font-style: italic;
    }

    @media (max-width: 600px) {
      .home-hero h1 { font-size: 2rem; }
      .home-hero { margin: 2.5rem auto 2rem; }
      .article-card { padding: 1rem 0.5rem; }
      .card-featured { padding: 1rem; }
      .tags-index-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
      .nav-links { gap: 0; }
      .nav-links a { padding: 0.375rem 0.5rem; font-size: 0.875rem; }
    }

    @media print {
      header, footer, .skip-link { display: none; }
      body { font-size: 12pt; line-height: 1.5; color: #000; background: #fff; }
      a { color: #000; text-decoration: underline; }
      pre, code { background: #f5f5f5; border: 1px solid #ccc; }
      .container, .container-wide { max-width: 100%; padding: 0; }
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <slot />
</body>
</html>
