---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  article?: boolean;
  tags?: string[];
}

const { title, description, image, canonicalURL, pubDate, updatedDate, author = 'AI Newsroom', article = false, tags = [] } = Astro.props;
const site = Astro.site?.toString() || 'https://news.lesbass.com';
const fullTitle = title === 'AI Newsroom' ? title : `${title} — AI Newsroom`;
const pageURL = canonicalURL || new URL(Astro.url.pathname, site).toString();

function truncateDescription(text: string, maxLen = 155): string {
  if (text.length <= maxLen) return text;
  const cut = text.slice(0, maxLen);
  const lastPeriod = cut.lastIndexOf('. ');
  const lastExcl = cut.lastIndexOf('! ');
  const lastQuest = cut.lastIndexOf('? ');
  const lastBreak = Math.max(lastPeriod, lastExcl, lastQuest);
  if (lastBreak > maxLen * 0.6) return text.slice(0, lastBreak + 1);
  return cut.slice(0, cut.lastIndexOf(' ')) + '…';
}

const seoDescription = truncateDescription(description);

const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'NewsArticle',
      headline: title,
      description: description,
      url: pageURL,
      image: new URL(image || '/favicon.svg', site).toString(),
      datePublished: pubDate ? pubDate.toISOString() : undefined,
      dateModified: updatedDate ? updatedDate.toISOString() : pubDate ? pubDate.toISOString() : undefined,
      author: {
        '@type': 'Organization',
        name: author,
        url: site,
      },
      publisher: {
        '@type': 'Organization',
        name: 'AI Newsroom',
        logo: {
          '@type': 'ImageObject',
          url: new URL('/favicon.svg', site).toString(),
        },
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'AI Newsroom',
      url: site,
      description: description,
    };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={seoDescription} />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0b0b0b" media="(prefers-color-scheme: dark)" />
  <link rel="canonical" href={pageURL} />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="alternate" type="application/rss+xml" title="AI Newsroom" href="/rss.xml" />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={seoDescription} />
  <meta property="og:url" content={pageURL} />
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={image ? new URL(image, site).toString() : new URL('/favicon.svg', site).toString()} />
  <meta property="og:site_name" content="AI Newsroom" />

  <!-- Twitter -->
  <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={seoDescription} />
  <meta name="twitter:image" content={image ? new URL(image, site).toString() : new URL('/favicon.svg', site).toString()} />

  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {article && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {article && tags.map(tag => <meta property="article:tag" content={tag} />)}

  <!-- JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <style is:global>
    :root {
      --color-bg: #ffffff;
      --color-text: #1a1a1a;
      --color-muted: #555555;
      --color-border: #e5e5e5;
      --color-accent: #2563eb;
      --font-heading: Georgia, 'Times New Roman', serif;
      --font-body: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      --max-width: 720px;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --color-bg: #0b0b0b;
        --color-text: #eeeeee;
        --color-muted: #aaaaaa;
        --color-border: #333333;
        --color-accent: #60a5fa;
      }
    }
    * { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      margin: 0;
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.6;
      overflow-wrap: break-word;
    }
    a { color: var(--color-accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    table {
      display: block;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border-collapse: collapse;
    }
    th, td {
      border: 1px solid var(--color-border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }
    th { background: var(--color-border); font-weight: 600; }
    pre, code { font-family: var(--font-mono); font-size: 0.95em; }
    pre {
      background: var(--color-border);
      padding: 1rem;
      border-radius: 0.5rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    blockquote {
      border-left: 4px solid var(--color-accent);
      margin: 1rem 0;
      padding-left: 1rem;
      color: var(--color-muted);
    }
    h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); line-height: 1.25; margin: 1.5rem 0 0.75rem; font-weight: 700; }
    h1 { font-size: 1.75rem; letter-spacing: -0.015em; }
    h2 { font-size: 1.35rem; letter-spacing: -0.01em; }
    h3 { font-size: 1.15rem; }
    p { margin: 0.75rem 0; }
    ul, ol { margin: 0.75rem 0; padding-left: 1.25rem; }
    .container {
      width: 100%;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1rem;
    }
    header, footer {
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 0;
    }
    footer {
      border-bottom: none;
      border-top: 1px solid var(--color-border);
      margin-top: 2rem;
      color: var(--color-muted);
      font-size: 0.9rem;
    }
    .nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .nav a { font-weight: 600; }
    .nav-links { display: flex; gap: 1rem; flex-wrap: wrap; }
    .nav-links a { min-height: 44px; display: inline-flex; align-items: center; }
    .article-list { list-style: none; padding: 0; }
    .article-list li { border-bottom: 1px solid var(--color-border); padding: 1rem 0; }
    .article-list a { font-size: 1.125rem; font-weight: 600; }
    .article-meta { color: var(--color-muted); font-size: 0.875rem; line-height: 1.5; }
    .article-header { margin: 1rem 0 1.5rem; }
    .article-header h1 { margin: 0; font-size: 2rem; }
    .article-body { font-size: 1.0625rem; }
    .article-desc { color: var(--color-muted); font-size: 0.9375rem; margin: 0.25rem 0 0; line-height: 1.5; }
    .tag { display: inline-block; background: var(--color-border); color: var(--color-muted); padding: 0.125rem 0.5rem; border-radius: 999px; font-size: 0.75rem; margin-right: 0.25rem; margin-bottom: 0.25rem; vertical-align: middle; }
    .home-hero { margin: 2.5rem 0 1.5rem; }
    .home-hero h1 { font-size: 2.25rem; margin: 0; }
    .home-tagline { color: var(--color-muted); font-size: 1.0625rem; margin: 0.5rem 0 0; }
    .section-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); margin: 2rem 0 0.75rem; font-family: var(--font-body); font-weight: 600; }
    .article-card-featured a { font-size: 1.35rem; }
    .article-card-featured .article-desc { font-size: 1rem; }
    .skip-link {
      position: absolute;
      top: -100%;
      left: 0;
      background: var(--color-accent);
      color: #fff;
      padding: 0.5rem 1rem;
      z-index: 100;
      font-weight: 600;
      text-decoration: none;
    }
    .skip-link:focus {
      top: 0;
    }
    .breadcrumb { font-size: 0.8125rem; color: var(--color-muted); margin: 0.5rem 0; }
    .breadcrumb ol { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.25rem; align-items: center; }
    .breadcrumb li { display: flex; align-items: center; gap: 0.25rem; }
    .breadcrumb a { color: var(--color-muted); }
    .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
    .breadcrumb-sep { color: var(--color-border); user-select: none; }
    .reading-time { font-size: 0.8125rem; color: var(--color-muted); }
    .article-hero { margin: 0 0 1.5rem; }
    .article-hero img {
      width: 100%;
      height: auto;
      border-radius: 0.5rem;
      border: 1px solid var(--color-border);
    }
    .article-hero-credit {
      margin: 0.375rem 0 0;
      font-size: 0.75rem;
      color: var(--color-muted);
      font-style: italic;
    }

    @media print {
      header, footer, .skip-link { display: none; }
      body { font-size: 12pt; line-height: 1.5; color: #000; background: #fff; }
      a { color: #000; text-decoration: underline; }
      pre, code { background: #f5f5f5; border: 1px solid #ccc; }
      .container { max-width: 100%; padding: 0; }
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <slot />
</body>
</html>
