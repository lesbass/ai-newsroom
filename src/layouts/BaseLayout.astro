---
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  article?: boolean;
  tags?: string[];
}

const { title, description, image, canonicalURL, pubDate, updatedDate, author = 'AI Newsroom', article = false, tags = [] } = Astro.props;
const site = 'https://news.lesbass.com/';
const rawFullTitle = title === 'AI Newsroom' ? title : `${title} — AI Newsroom`;
const fullTitle = rawFullTitle.length <= 65 ? rawFullTitle : title;
const pageURL = canonicalURL || new URL(Astro.url.pathname, site).toString();

function truncateTitle(text: string, maxLen = 65): string {
  if (text.length <= maxLen) return text;
  const cut = text.slice(0, maxLen + 1);
  const breaks = [':', ';', '—', '–', '|'];
  let best = -1;
  for (const b of breaks) {
    const idx = cut.lastIndexOf(b);
    if (idx > maxLen * 0.5) best = Math.max(best, idx);
  }
  if (best > 0) return text.slice(0, best).trimEnd();
  const lastSpace = cut.lastIndexOf(' ');
  if (lastSpace > maxLen * 0.5) return text.slice(0, lastSpace).trimEnd() + '…';
  return text.slice(0, maxLen).trimEnd() + '…';
}

const seoTitle = fullTitle.length <= 65 ? fullTitle : truncateTitle(fullTitle);

function truncateDescription(text: string, maxLen = 155): string {
  if (text.length <= maxLen) return text;
  const cut = text.slice(0, maxLen);
  const lastPeriod = cut.lastIndexOf('. ');
  const lastExcl = cut.lastIndexOf('! ');
  const lastQuest = cut.lastIndexOf('? ');
  const lastBreak = Math.max(lastPeriod, lastExcl, lastQuest);
  if (lastBreak > maxLen * 0.6) return text.slice(0, lastBreak + 1);
  return cut.slice(0, cut.lastIndexOf(' ')) + '…';
}

const seoDescription = truncateDescription(description);

const jsonLdImage = new URL(image || '/og-image.svg', site).toString();
const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'NewsArticle',
      '@id': `${pageURL}#article`,
      headline: title,
      description: description,
      url: pageURL,
      image: jsonLdImage,
      datePublished: pubDate ? pubDate.toISOString() : undefined,
      dateModified: updatedDate ? updatedDate.toISOString() : pubDate ? pubDate.toISOString() : undefined,
      author: {
        '@type': 'Organization',
        name: author,
        url: site,
      },
      publisher: {
        '@type': 'Organization',
        '@id': `${site}#organization`,
        name: 'AI Newsroom',
        url: site,
        logo: {
          '@type': 'ImageObject',
          url: new URL('/favicon.svg', site).toString(),
        },
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': pageURL,
      },
    }
      : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${site}#website`,
      name: 'AI Newsroom',
      url: site,
      description: description,
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${site}search?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{seoTitle}</title>
  <meta name="description" content={seoDescription} />
  <meta name="theme-color" content="#f3f6fb" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0b1020" media="(prefers-color-scheme: dark)" />
  <link rel="canonical" href={pageURL} />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="alternate" type="application/rss+xml" title="AI Newsroom" href="/rss.xml" />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={seoDescription} />
  <meta property="og:url" content={pageURL} />
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={image ? new URL(image, site).toString() : new URL('/og-image.svg', site).toString()} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="AI Newsroom" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={seoDescription} />
  <meta name="twitter:image" content={image ? new URL(image, site).toString() : new URL('/og-image.svg', site).toString()} />
  <meta name="twitter:image:alt" content={title} />
  <meta property="og:image:alt" content={title} />

  {article && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {article && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {article && tags.map(tag => <meta property="article:tag" content={tag} />)}

  <!-- JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <style is:inline>
    @font-face {
      font-family: "Atkinson Hyperlegible";
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url("/fonts/atkinson-400-latin.woff2") format("woff2");
    }
    @font-face {
      font-family: "Atkinson Hyperlegible";
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url("/fonts/atkinson-700-latin.woff2") format("woff2");
    }
    @font-face {
      font-family: "Fraunces";
      font-style: normal;
      font-weight: 600 700;
      font-display: swap;
      src: url("/fonts/fraunces-600-700-latin.woff2") format("woff2");
    }
    @font-face {
      font-family: "IBM Plex Mono";
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url("/fonts/ibm-plex-mono-400-latin.woff2") format("woff2");
    }
    @font-face {
      font-family: "IBM Plex Mono";
      font-style: normal;
      font-weight: 500;
      font-display: swap;
      src: url("/fonts/ibm-plex-mono-500-latin.woff2") format("woff2");
    }
    @font-face {
      font-family: "IBM Plex Mono";
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src: url("/fonts/ibm-plex-mono-600-latin.woff2") format("woff2");
    }
    @font-face {
      font-family: "IBM Plex Mono";
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url("/fonts/ibm-plex-mono-700-latin.woff2") format("woff2");
    }
    :root {
      color-scheme: light;
      --color-bg: #f3f6fb;
      --color-surface: rgba(248, 251, 255, 0.88);
      --color-surface-strong: #fbfdff;
      --color-text: #101827;
      --color-muted: #536174;
      --color-faint: #7a8798;
      --color-border: #cbd6e6;
      --color-accent: #1d4f91;
      --color-accent-hover: #0f6fb7;
      --color-accent-subtle: rgba(29, 79, 145, 0.11);
      --color-highlight: #c2563f;
      --color-highlight-subtle: rgba(194, 86, 63, 0.11);
      --color-brass: #8b6f2f;
      --color-grid: rgba(29, 79, 145, 0.078);
      --color-grid-strong: rgba(29, 79, 145, 0.26);
      --color-tick: rgba(15, 111, 183, 0.6);
      --font-heading: "Fraunces", Georgia, 'Times New Roman', serif;
      --font-body: "Atkinson Hyperlegible", system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      --font-mono: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      --max-width: 760px;
      --radius-sm: 0.125rem;
      --radius-md: 0.25rem;
      --radius-lg: 0.375rem;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        color-scheme: dark;
        --color-bg: #0b1020;
        --color-surface: rgba(15, 23, 42, 0.88);
        --color-surface-strong: #111a2e;
        --color-text: #eef4ff;
        --color-muted: #a9b8cf;
        --color-faint: #7f91ad;
        --color-border: #2a3a58;
        --color-accent: #7db7ff;
        --color-accent-hover: #9fd3ff;
        --color-accent-subtle: rgba(125, 183, 255, 0.13);
        --color-highlight: #f08a72;
        --color-highlight-subtle: rgba(240, 138, 114, 0.13);
        --color-brass: #d5b765;
        --color-grid: rgba(125, 183, 255, 0.075);
        --color-grid-strong: rgba(125, 183, 255, 0.24);
        --color-tick: rgba(125, 183, 255, 0.58);
      }
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: var(--font-body);
      background:
        linear-gradient(0deg, transparent calc(100% - 1px), var(--color-grid) 100%) 0 0 / 4rem 4rem,
        linear-gradient(90deg, var(--color-grid) 0 1px, transparent 1px 100%) 0 0 / 4rem 4rem,
        var(--color-bg);
      color: var(--color-text);
      line-height: 1.7;
      overflow-wrap: break-word;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    a {
      color: inherit;
      text-decoration-color: rgba(200, 79, 56, 0.48);
      text-decoration-thickness: 0.08em;
      text-underline-offset: 0.18em;
      transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    }
    a:hover { color: var(--color-accent-hover); }
    a:focus-visible {
      outline: 3px solid var(--color-accent);
      outline-offset: 4px;
    }
    img { max-width: 100%; height: auto; display: block; }
    table {
      display: block;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border-collapse: collapse;
      font-size: 0.9375rem;
    }
    th, td {
      border: 1px solid var(--color-border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }
    th { background: var(--color-border); font-weight: 600; }
    pre, code { font-family: var(--font-mono); font-size: 0.9em; }
    pre {
      background: var(--color-surface-strong);
      border: 1px solid var(--color-border);
      padding: 1rem 1.25rem;
      border-radius: var(--radius-md);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      line-height: 1.6;
    }
    code { font-size: 0.9em; }
    :not(pre) > code {
      background: var(--color-border);
      padding: 0.125rem 0.375rem;
      border-radius: var(--radius-sm);
      font-size: 0.875em;
    }
    blockquote {
      border-left: 3px solid var(--color-accent);
      margin: 1.25rem 0;
      padding: 0.5rem 0 0.5rem 1.25rem;
      color: var(--color-muted);
      font-style: italic;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      line-height: 1.3;
      margin: 2rem 0 0.75rem;
      font-weight: 700;
      color: var(--color-text);
    }
    h1 { font-size: 1.875rem; letter-spacing: 0; }
    h2 { font-size: 1.5rem; letter-spacing: 0; }
    h3 { font-size: 1.25rem; }
    h4 { font-size: 1.1rem; }
    p { margin: 0.75rem 0; }
    ul, ol { margin: 0.75rem 0; padding-left: 1.5rem; }
    li { margin: 0.25rem 0; }
    .container {
      width: 100%;
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    .container-wide {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    header {
      width: min(1120px, calc(100% - 2rem));
      margin: 0 auto;
      background: transparent;
      border-bottom: 1px solid var(--color-border);
      z-index: 50;
    }
    header .container {
      max-width: none;
      padding-left: 0;
      padding-right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
      padding-top: 1.15rem;
      padding-bottom: 1.15rem;
    }
    footer {
      width: min(1120px, calc(100% - 2rem));
      margin: 5rem auto 0;
      background: transparent;
      border-top: 1px solid var(--color-border);
      padding: 2rem 0 3rem;
      color: var(--color-muted);
      font-size: 0.875rem;
    }
    footer .container {
      max-width: none;
      padding-left: 0;
      padding-right: 0;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem 2rem;
      align-items: end;
    }
    .footer-brand {
      margin: 0 0 0.35rem;
      color: var(--color-text);
      font-family: var(--font-heading);
      font-size: 1.25rem;
      line-height: 1.05;
    }
    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.85rem;
      justify-content: flex-end;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .nav-links { display: flex; gap: 0.35rem 0.85rem; flex-wrap: wrap; align-items: center; }
    .nav-links a {
      font-family: var(--font-mono);
      font-weight: 600;
      font-size: 0.76rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.25rem 0;
      border-bottom: 2px solid transparent;
      min-height: 34px;
      display: inline-flex;
      align-items: center;
      color: var(--color-muted);
    }
    .nav-links a:hover { border-color: var(--color-highlight); color: var(--color-highlight); text-decoration: none; }
    .nav-links a.current { border-color: var(--color-accent); color: var(--color-accent); }
    .site-logo {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      min-height: 44px;
      color: var(--color-text);
      text-decoration: none;
    }
    .site-mark {
      display: inline-grid;
      width: 2.7rem;
      height: 2.7rem;
      flex: 0 0 auto;
      place-items: center;
      border: 1px solid var(--color-border);
      background:
        linear-gradient(135deg, transparent 0 46%, var(--color-tick) 46% 54%, transparent 54%),
        var(--color-surface);
      color: var(--color-accent);
      font-family: var(--font-mono);
      font-size: 0.74rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      box-shadow: 0 0.45rem 1.1rem rgba(16, 22, 21, 0.12);
    }
    .site-logo-text {
      display: grid;
      gap: 0.05rem;
    }
    .site-logo-name {
      font-family: var(--font-heading);
      font-size: clamp(1.2rem, 3vw, 1.55rem);
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0;
    }
    .site-logo-kicker {
      color: var(--color-accent);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      line-height: 1;
    }
    .site-logo:hover { color: var(--color-highlight); text-decoration: none; }
    .article-list { list-style: none; padding: 0; margin: 0; }
    .article-list > li { margin-bottom: 0; }
    .article-card {
      position: relative;
      display: block;
      padding: 1.45rem 0 1.55rem 1.15rem;
      border-bottom: 1px solid var(--color-border);
      transition: background 0.15s ease, padding-left 0.15s ease;
    }
    .article-card::before {
      content: "";
      position: absolute;
      top: 1.9rem;
      left: 0;
      width: 0.48rem;
      height: 0.13rem;
      background: var(--color-tick);
    }
    .article-card:hover { background: var(--color-accent-subtle); }
    .article-card:first-child { border-top: 1px solid var(--color-border); }
    .article-card-title {
      font-family: var(--font-heading);
      font-size: clamp(1.25rem, 2.5vw, 1.65rem);
      font-weight: 700;
      line-height: 1.12;
      display: block;
      margin-bottom: 0.45rem;
      color: var(--color-text);
      text-decoration: none;
    }
    .article-meta {
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      line-height: 1.6;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.25rem;
    }
    .article-desc {
      color: var(--color-muted);
      font-size: 0.98rem;
      margin: 0.65rem 0 0;
      line-height: 1.6;
    }
    .article-header { margin: 1rem 0 2rem; }
    .article-header h1 {
      margin: 0 0 0.5rem;
      font-size: clamp(2.2rem, 6vw, 4.45rem);
      line-height: 1.02;
    }
    .article-body {
      font-size: 1.0625rem;
      line-height: 1.75;
    }
    .article-body h2 { margin-top: 2.5rem; }
    .article-body h3 { margin-top: 2rem; }
    .tag {
      display: inline-flex;
      align-items: center;
      min-height: 1.8rem;
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      color: var(--color-muted);
      padding: 0.18rem 0.55rem;
      border-radius: var(--radius-sm);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      white-space: nowrap;
      text-decoration: none;
      transition: background 0.15s ease, color 0.15s ease;
      line-height: 1.4;
    }
    a.tag:hover {
      background: var(--color-accent-subtle);
      color: var(--color-accent);
      text-decoration: none;
    }
    .tag-highlight {
      background: var(--color-highlight-subtle);
      color: var(--color-highlight);
      border-color: rgba(200, 79, 56, 0.35);
      font-weight: 600;
    }
    .home-hero {
      position: relative;
      width: min(1120px, calc(100% - 2rem));
      margin: 0 auto;
      padding: clamp(3.4rem, 8vw, 6rem) 0 clamp(2rem, 5vw, 3.6rem) clamp(2rem, 4vw, 3.25rem);
      text-align: left;
      border-bottom: 1px solid var(--color-border);
    }
    .home-hero::before {
      content: "";
      position: absolute;
      top: clamp(3rem, 8vw, 5.6rem);
      bottom: clamp(2rem, 5vw, 3.4rem);
      left: 0;
      width: 0.42rem;
      background:
        repeating-linear-gradient(to bottom, var(--color-tick) 0 0.7rem, transparent 0.7rem 1.35rem),
        linear-gradient(to bottom, var(--color-grid-strong), var(--color-grid-strong)) 50% 0 / 1px 100% no-repeat;
    }
    .home-hero h1 {
      max-width: 11ch;
      font-size: clamp(3rem, 7vw, 5.8rem);
      line-height: 0.98;
      margin: 0 0 0.65rem;
    }
    .home-tagline {
      color: var(--color-muted);
      font-size: clamp(1.05rem, 1.7vw, 1.2rem);
      margin: 0;
      line-height: 1.55;
      max-width: 42rem;
    }
    .section-label {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-accent);
      margin: 3rem 0 1rem;
      font-family: var(--font-mono);
      font-weight: 700;
    }
    .card-featured {
      position: relative;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-left: 0.45rem solid var(--color-accent);
      border-radius: var(--radius-lg);
      padding: clamp(1.25rem, 3vw, 1.75rem);
      margin-bottom: 1.5rem;
      box-shadow: 0 1.1rem 2.2rem rgba(16, 22, 21, 0.08);
    }
    .card-featured::before { display: none; }
    .card-featured .article-card-title { font-size: clamp(1.7rem, 4vw, 2.55rem); }
    .card-featured .article-desc { font-size: 1rem; }
    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1rem 0;
    }
    .tag-cloud .tag {
      font-size: 0.8125rem;
      padding: 0.3rem 0.75rem;
    }
    .tag-page-header {
      margin: clamp(3rem, 8vw, 5rem) 0 2rem;
      text-align: left;
    }
    .tag-page-header h1 { font-size: clamp(2.4rem, 6vw, 4rem); margin-bottom: 0.35rem; }
    .tag-page-header .tag-page-count { color: var(--color-muted); font-size: 0.9375rem; }
    .tags-index-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0.5rem;
      margin: 1.5rem 0;
    }
    .tag-index-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.65rem 0.75rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.15s ease, border-color 0.15s ease;
    }
    .tag-index-card:hover {
      background: var(--color-accent-subtle);
      border-color: var(--color-accent);
      text-decoration: none;
      color: var(--color-accent);
    }
    .tag-index-count {
      color: var(--color-faint);
      font-size: 0.75rem;
      font-weight: 600;
    }
    .skip-link {
      position: absolute;
      top: -100%;
      left: 0;
      background: var(--color-accent);
      color: #fff;
      padding: 0.5rem 1rem;
      z-index: 100;
      font-weight: 600;
      text-decoration: none;
      border-radius: 0 0 var(--radius-sm) 0;
    }
    .skip-link:focus { top: 0; }
    .breadcrumb { font-size: 0.8125rem; color: var(--color-muted); margin: 0.25rem 0 0.75rem; }
    .breadcrumb ol { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.25rem; align-items: center; }
    .breadcrumb li { display: flex; align-items: center; gap: 0.25rem; }
    .breadcrumb a { color: var(--color-muted); }
